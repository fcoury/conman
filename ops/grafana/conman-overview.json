{
  "title": "Conman Overview",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "type": "timeseries",
      "title": "HTTP Request Rate",
      "targets": [
        {
          "expr": "sum(rate(conman_http_requests_total[5m]))",
          "legendFormat": "req/s"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP p95 Latency",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(conman_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Job Queue Depth",
      "targets": [
        {
          "expr": "conman_job_queue_depth",
          "legendFormat": "depth"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Deployments",
      "targets": [
        {
          "expr": "sum(increase(conman_deployments_total[15m]))",
          "legendFormat": "deploy events/15m"
        }
      ]
    }
  ]
}
