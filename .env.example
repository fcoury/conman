CONMAN_HOST=127.0.0.1
CONMAN_PORT=3000

CONMAN_MONGO_URI=mongodb://localhost:27017
CONMAN_MONGO_DB=conman
CONMAN_GITALY_ADDRESS=http://127.0.0.1:2305

# Required (minimum 32 chars).
CONMAN_JWT_SECRET=replace-this-with-a-very-long-local-dev-secret-1234
CONMAN_JWT_EXPIRY_HOURS=24
CONMAN_INVITE_EXPIRY_DAYS=7

# Required.
CONMAN_SECRETS_MASTER_KEY=local-dev-master-key
CONMAN_TEMP_URL_DOMAIN=config.example.test

CONMAN_HTTP_RATE_LIMIT_PER_SECOND=200

# Gate command hooks (defaults are "true"; set real commands when available).
CONMAN_MSUITE_SUBMIT_CMD=true
CONMAN_MSUITE_MERGE_CMD=true
CONMAN_MSUITE_DEPLOY_CMD=true
CONMAN_DEPLOY_RELEASE_CMD=true
CONMAN_RUNTIME_PROFILE_DRIFT_CHECK_CMD=true

# Optional temp-env hooks.
# CONMAN_TEMP_ENV_PROVISION_CMD=
# CONMAN_TEMP_ENV_EXPIRE_CMD=

# Optional SMTP configuration (set all required fields together).
# CONMAN_SMTP_HOST=smtp.example.com
# CONMAN_SMTP_PORT=587
# CONMAN_SMTP_USERNAME=
# CONMAN_SMTP_PASSWORD=
# CONMAN_SMTP_FROM_EMAIL=noreply@example.com
